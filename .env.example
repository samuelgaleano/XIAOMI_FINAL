# Gemini (optional for this commerce flow)
GEMINI_API_KEY=""

# Public app URL
APP_URL="https://xiaomicartech.com.co"

# Wompi integration
WOMPI_PUBLIC_KEY="pub_prod_xxx"
WOMPI_PRIVATE_KEY="prv_prod_xxx"
WOMPI_INTEGRITY_SECRET="prod_integrity_xxx"
WOMPI_EVENTS_SECRET="prod_events_xxx"

# Resend integration
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="ventas@xiaomicartech.com.co"
RESEND_ADMIN_EMAIL="ventas@xiaomicartech.com.co"

# Meta Conversions API (Events Manager > Pixel > Configuracion > Conversions API > Generar token de acceso)
META_CAPI_ACCESS_TOKEN="xxx"
# Opcional: solo mientras se verifica en Events Manager > Test Events
META_TEST_EVENT_CODE=""

# Panel de administración (OBLIGATORIO para gestionar pedidos).
# Sin estas variables el login de admin queda deshabilitado (falla de forma segura).
ADMIN_EMAIL="tu-correo@dominio.com"
ADMIN_PASSWORD="usa-una-contraseña-fuerte-y-única"
# Secreto para firmar los tokens de sesión (64 hex aleatorios recomendado).
# Si se omite, se genera uno efímero por proceso (la sesión se cierra al reiniciar).
ADMIN_SESSION_SECRET="cambia-esto-por-un-secreto-largo-aleatorio"
