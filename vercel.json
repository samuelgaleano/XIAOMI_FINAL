{
  "version": 2,
  "builds": [
    { 
      "src": "api_index.ts", 
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server.ts", "metaCapi.ts"],
        "bundle": true
      }
    },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api_index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
